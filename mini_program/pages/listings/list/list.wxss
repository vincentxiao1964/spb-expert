.container {
  background-color: #f5f5f5;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Filter Bar */
.filter-bar {
  display: flex;
  background-color: #fff;
  padding: 10px 0;
  border-bottom: 1px solid #eee;
  position: sticky;
  top: 0;
  z-index: 100;
}

.filter-item {
  flex: 1;
  text-align: center;
  font-size: 14px;
  color: #666;
  position: relative;
  padding-bottom: 5px;
}

.filter-item.active {
  color: #007bff;
  font-weight: bold;
}

.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 20px;
  height: 2px;
  background-color: #007bff;
}

/* Listings List */
.listings-scroll {
  flex: 1;
  /* height: 0; Removed to allow better flex behavior or fallback */
  padding: 10px;
  box-sizing: border-box;
  /* Ensure it has a height if flex fails */
  height: calc(100vh - 100rpx); 
}

.listing-item {
  background-color: #fff;
  border-radius: 8px;
  padding: 15px;
  margin-bottom: 15px;
  box-shadow: 0 2px 5px rgba(0,0,0,0.05);
}

.listing-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
}

.listing-type {
  font-size: 12px;
  padding: 2px 6px;
  border-radius: 4px;
  color: #fff;
}
.listing-type.SELL { background-color: #28a745; }
.listing-type.BUY { background-color: #ffc107; color: #333; }
.listing-type.CHARTER_OFFER { background-color: #17a2b8; }
.listing-type.CHARTER_REQUEST { background-color: #6c757d; }

.listing-date {
  font-size: 12px;
  color: #999;
}

.listing-main {
  display: flex;
  margin-bottom: 10px;
}

.listing-thumb {
  width: 80px;
  height: 60px;
  border-radius: 4px;
  background-color: #eee;
  margin-right: 10px;
  flex-shrink: 0;
}

.listing-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.listing-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 5px;
}

.listing-specs {
  font-size: 12px;
  color: #666;
  margin-bottom: 5px;
}

.listing-area {
  font-size: 12px;
  color: #999;
}

.listing-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid #f8f8f8;
  padding-top: 10px;
}

.status-text {
  font-size: 12px;
  color: #666;
}

.btn-detail {
  margin: 0;
  background-color: #007bff;
  color: #fff;
  font-size: 12px;
}

.loading-more, .no-more, .empty-state {
  text-align: center;
  padding: 20px;
  color: #999;
  font-size: 14px;
}

/* FAB Styles */
.fab-btn {
  position: fixed;
  bottom: 30px;
  right: 20px;
  width: 60px;
  height: 60px;
  background-color: #007bff;
  border-radius: 50%;
  box-shadow: 0 4px 10px rgba(0,0,0,0.3);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.fab-icon {
  color: white;
  font-size: 24px;
  line-height: 24px;
  margin-bottom: 2px;
}

.fab-text {
  color: white;
  font-size: 10px;
  line-height: 12px;
}
