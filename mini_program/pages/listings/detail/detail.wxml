<view class="container" style="padding-bottom: 150rpx;">
  <block wx:if="{{loading}}">
    <view class="loading">{{t.loading}}...</view>
  </block>
  <block wx:elif="{{listing}}">
    <view class="title">
      <view class="title-row">
        <text class="tag {{listing.listing_type}}">{{listing.listing_type_display}}</text> 
        <text>{{listing.ship_category_display}} - {{listing.dwt}}t</text>
        <view class="fav-btn" bindtap="toggleFavorite">
           <text style="color: {{isFavorite ? 'red' : '#999'}};">{{isFavorite ? '♥' : '♡'}}</text>
        </view>
      </view>
      <view class="unique-id" style="font-size: 24rpx; color: #666; margin-top: 10rpx;">ID: {{listing.unique_id || 'Generating...'}}</view>
    </view>
    <view class="info">
      <view>{{t.length}}: {{listing.length}}m</view>
      <view>{{t.width}}: {{listing.width}}m</view>
      <view>{{t.build_year}}: {{listing.build_year}}</view>
      <view>{{t.status}}: {{listing.status_display}}</view>
    </view>
    <view class="description">
      <text>{{listing.description}}</text>
    </view>

    <!-- Hymart Extended Info Section -->
    <view class="extended-info-section" wx:if="{{listing.extended_info}}">
      <view class="section-title">Hymart 船舶数据</view>
      <view class="info-grid">
        <view class="info-item" wx:if="{{listing.extended_info.draft_laden}}">
          <text class="label">满载吃水</text>
          <text class="value">{{listing.extended_info.draft_laden}} m</text>
        </view>
        <view class="info-item" wx:if="{{listing.extended_info.draft_ballast}}">
          <text class="label">空载吃水</text>
          <text class="value">{{listing.extended_info.draft_ballast}} m</text>
        </view>
        <view class="info-item" wx:if="{{listing.extended_info.grain_capacity}}">
          <text class="label">散装舱容</text>
          <text class="value">{{listing.extended_info.grain_capacity}} m³</text>
        </view>
        <view class="info-item" wx:if="{{listing.extended_info.hatch_size}}">
          <text class="label">舱口尺寸</text>
          <text class="value">{{listing.extended_info.hatch_size}}</text>
        </view>
        <view class="info-item" wx:if="{{listing.extended_info.speed_laden}}">
          <text class="label">重载航速</text>
          <text class="value">{{listing.extended_info.speed_laden}} kn</text>
        </view>
        <view class="info-item" wx:if="{{listing.extended_info.fuel_consumption_sea}}">
          <text class="label">航行油耗</text>
          <text class="value">{{listing.extended_info.fuel_consumption_sea}} t/d</text>
        </view>
      </view>
    </view>
    
    <view class="contact-section">
      <view class="section-title">{{t.contact_info}}</view>
      <block wx:if="{{listing.contact_info}}">
        <view class="contact-content">{{listing.contact_info}}</view>
        <view class="action-buttons" wx:if="{{listing.user}}">
            <button class="btn-action btn-follow {{isFollowing ? 'active' : ''}}" size="mini" bindtap="toggleFollow">
                {{isFollowing ? t.unfollow_author : t.follow_author}}
            </button>
            <button class="btn-action btn-contact" size="mini" bindtap="contactUser">
                {{t.contact_author}}
            </button>
            <button class="btn-action btn-share" size="mini" bindtap="generatePoster">
                {{t.share_poster}}
            </button>
            <button class="btn-action btn-favorite {{isFavorite ? 'active' : ''}}" size="mini" bindtap="toggleFavorite">
                {{isFavorite ? t.favorited : t.favorite_verb}}
            </button>
        </view>
      </block>
      <block wx:elif="{{!isLoggedIn}}">
        <view class="login-tip">
          <text>{{t.login_to_view_contact}}</text>
          <button class="btn-login" size="mini" bindtap="goToLogin">{{t.go_login}}</button>
        </view>
      </block>
      <block wx:else>
        <view class="login-tip" style="background-color: #f5f5f5; color: #999;">
          <text>{{t.no_contact_info || '暂无联系方式'}}</text>
        </view>
      </block>
    </view>
    
    <view class="images" wx:if="{{listing.images && listing.images.length > 0}}">
      <block wx:for="{{listing.images}}" wx:key="id">
        <image src="{{item.image}}" mode="widthFix" style="width: 100%; margin-top: 10rpx;"></image>
      </block>
    </view>

    <view class="owner-actions" wx:if="{{listing.is_owner}}">
      <button class="btn-edit" bindtap="onEdit">{{t.edit}}</button>
      <button class="btn-delete" bindtap="onDelete">{{t.delete}}</button>
    </view>
    
    <!-- Transaction Button (For Buyers) -->
    <view class="transaction-action" wx:if="{{!listing.is_owner && listing.status === 'APPROVED' && listing.contact_info}}">
        <button class="btn-transaction" bindtap="initiateTransaction">{{t.initiate_transaction}}</button>
    </view>
  </block>
  <block wx:else>
    <view class="error">{{t.not_found}}</view>
  </block>

  <!-- Floating Publish Button -->
  <view class="fab-btn" bindtap="onPublish">
    <text>+</text>
  </view>

  <quick-nav />

  <!-- Hidden Canvas for Poster Generation -->
  <canvas canvas-id="posterCanvas" style="width: 375px; height: 550px; position: fixed; left: 9000px;"></canvas>
</view>
