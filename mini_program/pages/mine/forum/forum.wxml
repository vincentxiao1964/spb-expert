<view class="container" style="padding-bottom: 300rpx;">
  <block wx:if="{{loading}}">
    <view class="loading">加载中...</view>
  </block>
  <block wx:elif="{{messages.length > 0}}">
    <block wx:for="{{messages}}" wx:key="id">
      <view class="message-item" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="message-header">
            <text class="title">{{item.content}}</text>
        </view>
        <view class="message-meta">
            <text class="time">{{item.created_at}}</text>
            <text class="reply-count">回复: {{item.reply_count}}</text>
        </view>
      </view>
    </block>
  </block>
  <block wx:else>
    <view class="empty">
        <view>您还没有发布任何论坛帖子</view>
        <view style="font-size: 12px; color: #999; margin-top: 10px;" wx:if="{{username}}">当前登录账号: {{username}}</view>
        <view style="font-size: 12px; color: #999; margin-top: 5px;">如果您使用了微信一键登录，账号可能与网站账号不同</view>
    </view>
  </block>
  <quick-nav />
</view>
