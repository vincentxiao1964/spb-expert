.container {
  padding: 20px;
  padding-bottom: 120rpx;
}
.form-group {
  margin-bottom: 20px;
}
.label {
  font-size: 14px;
  color: #666;
  margin-bottom: 5px;
}
.input {
  border: 1px solid #ddd;
  padding: 10px;
  border-radius: 4px;
  font-size: 16px;
  background: #fff;
}
.input[disabled] {
  background: #f5f5f5;
  color: #999;
}
.btn-save {
  margin-top: 40rpx;
  background-color: #007aff;
  color: #fff;
  border-radius: 8rpx;
}

.extra-actions {
    margin-top: 40rpx;
    background: #fff;
    border-radius: 8rpx;
}

.action-item {
    display: flex;
    justify-content: space-between;
    padding: 30rpx;
    border-bottom: 1rpx solid #eee;
    font-size: 30rpx;
}

.action-item:last-child {
    border-bottom: none;
}

.arrow {
    color: #999;
}

.btn-logout {
  margin-top: 30rpx;
  background-color: #f5f5f5;
  color: #d9534f;
  border: 1px solid #e0e0e0;
  border-radius: 10rpx;
}