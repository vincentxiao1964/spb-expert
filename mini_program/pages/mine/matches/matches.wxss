.container {
  padding: 20px;
  padding-bottom: 300rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}
.loading, .empty {
  text-align: center;
  color: #999;
  margin-top: 50px;
}
.match-item {
  background: #fff;
  border-radius: 8px;
  padding: 15px;
  margin-bottom: 15px;
  box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}
.match-header {
  display: flex;
  justify-content: space-between;
  border-bottom: 1px solid #eee;
  padding-bottom: 10px;
  margin-bottom: 10px;
}
.match-title {
  font-weight: bold;
  font-size: 16px;
  color: #333;
}
.match-score {
  color: #999;
  font-size: 12px;
}
.match-body {
  margin-bottom: 15px;
}
.match-row {
    display: flex;
    margin-bottom: 8px;
}
.label {
    color: #666;
    font-size: 14px;
    width: 80px;
    flex-shrink: 0;
}
.value {
    color: #333;
    font-size: 14px;
    flex: 1;
}
.match-actions {
  display: flex;
  justify-content: flex-end;
}
.match-actions button {
  margin-left: 10px;
  margin-right: 0;
}
