.container {
  background-color: #f5f5f5;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Listings List */
.listings-scroll {
  flex: 1;
  height: 0; /* Important for flex column scrolling */
  padding: 10px;
  padding-bottom: 300rpx;
  box-sizing: border-box;
}

.listing-item {
  background-color: #fff;
  border-radius: 8px;
  padding: 15px;
  margin-bottom: 15px;
  box-shadow: 0 2px 5px rgba(0,0,0,0.05);
}

.listing-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
}

.listing-type {
  font-size: 12px;
  padding: 2px 6px;
  border-radius: 4px;
  color: #fff;
}
.listing-type.SELL { background-color: #28a745; }
.listing-type.BUY { background-color: #ffc107; color: #333; }
.listing-type.CHARTER_OFFER { background-color: #17a2b8; }
.listing-type.CHARTER_REQUEST { background-color: #6c757d; }

.listing-date {
  font-size: 12px;
  color: #999;
}

.listing-main {
  display: flex;
  margin-bottom: 10px;
}

.listing-thumb {
  width: 80px;
  height: 60px;
  border-radius: 4px;
  background-color: #eee;
  margin-right: 10px;
  flex-shrink: 0;
}

.listing-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.listing-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 5px;
}

.listing-specs {
  font-size: 12px;
  color: #666;
  margin-bottom: 5px;
}

.listing-area {
  font-size: 12px;
  color: #999;
}

.listing-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid #f8f8f8;
  padding-top: 10px;
}

.status-text {
  font-size: 12px;
  color: #666;
}

.btn-detail {
  margin: 0;
  background-color: #007bff;
  color: #fff;
  font-size: 12px;
}

.loading-more, .no-more, .empty-state {
  text-align: center;
  padding: 20px;
  color: #999;
  font-size: 14px;
}
