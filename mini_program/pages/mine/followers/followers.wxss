.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 300rpx;
}

.tabs {
    display: flex;
    background: #fff;
    margin-bottom: 20rpx;
    border-bottom: 1px solid #eee;
}

.tab {
    flex: 1;
    text-align: center;
    padding: 20rpx 0;
    font-size: 28rpx;
    color: #666;
    position: relative;
}

.tab.active {
    color: #007bff;
    font-weight: bold;
}

.tab.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 20%;
    width: 60%;
    height: 4rpx;
    background: #007bff;
}

.loading, .empty {
  text-align: center;
  color: #999;
  padding-top: 50px;
}

.follower-item {
  background-color: #fff;
  padding: 15px;
  border-bottom: 1px solid #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.follower-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.username {
  font-weight: bold;
  font-size: 16px;
  color: #333;
  margin-bottom: 5px;
}

.action {
  color: #666;
  font-size: 14px;
}

.listing-title {
  color: #3f51b5;
  font-size: 14px;
  margin-bottom: 5px;
}

.time {
  color: #999;
  font-size: 12px;
}

.actions button {
    font-size: 12px;
}
