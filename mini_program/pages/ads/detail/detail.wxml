<view class="container" style="padding-bottom: 300rpx;">
  <block wx:if="{{loading}}">
    <view class="loading">加载中...</view>
  </block>
  <block wx:elif="{{ad}}">
    <view class="ad-detail">
      <image wx:if="{{ad.image}}" src="{{ad.image}}" mode="widthFix" class="ad-image"></image>
      <view class="ad-info">
        <view class="ad-title-row">
            <view class="ad-title">{{ad.title}}</view>
            <view class="favorite-btn" bindtap="toggleFavorite">
                <text class="iconfont {{isFavorite ? 'icon-star-filled' : 'icon-star'}}"></text>
                <text>{{isFavorite ? '已收藏' : '收藏'}}</text>
            </view>
        </view>
        
        <view class="author-section" wx:if="{{ad.user}}">
            <view class="author-info">
                <text class="author-name">发布者: {{ad.user_name}}</text>
            </view>
            <view class="action-buttons">
                <button class="btn-action btn-follow {{isFollowing ? 'active' : ''}}" size="mini" bindtap="toggleFollow">
                    {{isFollowing ? '取消关注' : '关注作者'}}
                </button>
                <button class="btn-action btn-contact" size="mini" bindtap="contactUser">
                    联系作者
                </button>
            </view>
        </view>

        <view class="ad-content">
          <text>{{ad.description || '暂无详细描述'}}</text>
        </view>
        <view class="ad-meta">
          <text>发布时间：{{ad.created_at}}</text>
        </view>
      </view>
    </view>
  </block>
  <block wx:else>
     <view class="error">未找到广告信息</view>
  </block>
  <quick-nav />
</view>
