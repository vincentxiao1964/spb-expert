.container {
  padding: 10px;
  padding-bottom: 120rpx;
  background-color: #fff;
}
.ad-image {
  width: 100%;
  border-radius: 8px;
  margin-bottom: 15px;
}
.ad-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}
.ad-title {
  font-size: 20px;
  font-weight: bold;
  flex: 1;
}
.favorite-btn {
  display: flex;
  align-items: center;
  color: #666;
  font-size: 28rpx;
  margin-left: 20rpx;
}
.favorite-btn .iconfont {
  margin-right: 6rpx;
  font-size: 32rpx;
}
.icon-star-filled {
  color: #ffc107;
}

.author-section {
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}
.author-info {
  margin-bottom: 16rpx;
}
.author-name {
  font-weight: bold;
  font-size: 30rpx;
}
.action-buttons {
  display: flex;
  gap: 20rpx;
}
.btn-action {
  margin: 0;
  font-size: 24rpx;
  padding: 0 30rpx;
  line-height: 2.4;
}
.btn-follow {
  background-color: #fff;
  color: #007aff;
  border: 1px solid #007aff;
}
.btn-follow.active {
  background-color: #007aff;
  color: #fff;
}
.btn-contact {
  background-color: #fff;
  color: #17a2b8;
  border: 1px solid #17a2b8;
}

.ad-content {
  font-size: 16px;
  line-height: 1.6;
  color: #333;
  margin-bottom: 20px;
}
.ad-meta {
  font-size: 12px;
  color: #999;
}
.loading, .error {
  text-align: center;
  margin-top: 100rpx;
  color: #999;
  font-size: 30rpx;
}
