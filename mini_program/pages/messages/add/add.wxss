.container {
  padding: 30rpx;
  padding-bottom: 120rpx;
}

.tips {
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: #f0f8ff;
  border-radius: 8rpx;
}

.tips-title {
  display: block;
  font-weight: bold;
  font-size: 28rpx;
  margin-bottom: 10rpx;
  color: #333;
}

.tips text {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.form-group {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid #eee;
}

.input-area {
  width: 100%;
  height: 300rpx;
  font-size: 30rpx;
}

.char-count {
  text-align: right;
  color: #999;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.btn-submit {
  width: 100%;
}
