.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.forum-rules {
  background-color: #fff;
  margin: 20rpx;
  padding: 20rpx;
  border-radius: 10rpx;
  border-left: 8rpx solid #007aff;
}

.rules-title {
  font-weight: bold;
  font-size: 30rpx;
  margin-bottom: 10rpx;
  color: #333;
}

.rules-content view {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 5rpx;
}

.message-list {
  padding: 0 20rpx;
}

.message-item {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.message-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 10rpx;
}

.user-name {
  font-weight: bold;
  color: #333;
  font-size: 28rpx;
}

.message-time {
  color: #999;
  font-size: 24rpx;
}

.message-content {
  font-size: 30rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.message-footer {
    border-top: 1rpx dashed #eee;
    padding-top: 10rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.footer-left {
    display: flex;
    align-items: center;
}

.footer-right {
    display: flex;
    align-items: center;
}

.reply-count {
    font-size: 24rpx;
    color: #666;
    background-color: #f5f5f5;
    padding: 4rpx 12rpx;
    border-radius: 6rpx;
}

.btn-reply {
    font-size: 24rpx;
    background-color: #007aff;
    color: #fff;
    padding: 0 24rpx;
    height: 48rpx;
    line-height: 48rpx;
    border-radius: 24rpx;
    display: flex;
    align-items: center;
    justify-content: center;
}

.empty-tip, .loading-more, .no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

.fab-btn {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #007aff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.3);
  z-index: 100;
}

.fab-btn text {
  color: #fff;
  font-size: 60rpx;
  font-weight: bold;
  margin-top: -10rpx;
}

/* Top Tabs */
.top-tabs {
  display: flex;
  background: #fff;
  height: 80rpx;
  line-height: 80rpx;
  border-bottom: 1rpx solid #eee;
  z-index: 100;
}
.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
}
.tab-item.active {
  color: #007aff;
  font-weight: bold;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #007aff;
}
.badge {
  position: absolute;
  top: 10rpx;
  right: 20rpx;
  background: #ff3b30;
  color: white;
  font-size: 20rpx;
  padding: 0 8rpx;
  border-radius: 18rpx;
  line-height: 28rpx;
  min-width: 28rpx;
  text-align: center;
}

/* Conversations */
.conversation-item {
  display: flex;
  padding: 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  align-items: center;
}
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}
.conv-content {
  flex: 1;
}
.conv-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}
.conv-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}
.conv-time {
  font-size: 24rpx;
  color: #999;
}
.conv-bottom {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}
.conv-msg {
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 450rpx;
}
.conv-badge {
  background: #ff3b30;
  color: white;
  font-size: 20rpx;
  padding: 0 10rpx;
  border-radius: 18rpx;
  line-height: 30rpx;
}

/* Notifications */
.mark-read-container {
    padding: 20rpx;
    display: flex;
    justify-content: flex-end;
}
.mark-read-btn {
    font-size: 24rpx;
    color: #666;
    border: 1rpx solid #ccc;
    padding: 4rpx 16rpx;
    border-radius: 20rpx;
}
.notif-item {
    display: flex;
    padding: 20rpx;
    background: #fff;
    border-bottom: 1rpx solid #f0f0f0;
}
.notif-item.unread {
    background: #fff9f9;
}
.notif-icon-box {
    width: 80rpx;
    height: 80rpx;
    border-radius: 50%;
    margin-right: 20rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 32rpx;
}
.type-MESSAGE { background: #007aff; }
.type-REPLY { background: #34c759; }
.type-FOLLOW { background: #ff9500; }
.type-SYSTEM { background: #5856d6; }

.notif-content {
    flex: 1;
}
.notif-title {
    font-size: 28rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 6rpx;
}
.notif-body {
    font-size: 26rpx;
    color: #666;
    margin-bottom: 10rpx;
}
.notif-time {
    font-size: 22rpx;
    color: #999;
}
