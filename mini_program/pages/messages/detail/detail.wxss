.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 0;
}

.post-card {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background-color: #eee;
}

.user-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.post-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.favorite-btn {
  display: flex;
  align-items: center;
  color: #666;
  font-size: 28rpx;
  margin-left: 20rpx;
}
.favorite-btn .iconfont {
  margin-right: 6rpx;
  font-size: 32rpx;
}
.icon-star-filled {
  color: #ffc107;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.btn-action {
  margin: 0;
  font-size: 24rpx;
  padding: 0 30rpx;
  line-height: 2.4;
}
.btn-follow {
  background-color: #fff;
  color: #007aff;
  border: 1px solid #007aff;
}
.btn-follow.active {
  background-color: #007aff;
  color: #fff;
}
.btn-contact {
  background-color: #fff;
  color: #17a2b8;
  border: 1px solid #17a2b8;
}

.post-content {
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
}

.replies-section {
  background-color: #fff;
  padding: 30rpx;
  min-height: 300rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.reply-item {
  display: flex;
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #f9f9f9;
  padding-bottom: 20rpx;
}

.reply-item:last-child {
  border-bottom: none;
}

.reply-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #eee;
}

.reply-content-box {
  flex: 1;
}

.reply-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.reply-user {
  font-size: 28rpx;
  color: #576b95;
  font-weight: 500;
}

.reply-time {
  font-size: 22rpx;
  color: #bbb;
}

.reply-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.empty-reply {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
  font-size: 28rpx;
}

.reply-bar {
  position: fixed;
  bottom: calc(100rpx + constant(safe-area-inset-bottom));
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  left: 0;
  width: 100%;
  height: 100rpx;
  background-color: #fff;
  border-top: 1rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-sizing: border-box;
  z-index: 10000;
}

.login-btn {
    width: 100%;
    background-color: #007aff;
    color: #fff;
    font-size: 30rpx;
    border-radius: 40rpx;
    line-height: 80rpx;
    margin: 0 20rpx;
}

.reply-input {
  flex: 1;
  height: 70rpx;
  background-color: #f5f5f5;
  border-radius: 35rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.reply-btn {
  width: 120rpx;
  height: 70rpx;
  line-height: 70rpx;
  background-color: #1296db;
  color: #fff;
  font-size: 28rpx;
  border-radius: 10rpx;
  padding: 0;
  margin: 0;
}

.reply-btn[disabled] {
  background-color: #ccc !important;
  color: #fff !important;
}
