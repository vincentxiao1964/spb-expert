page {
  background-color: #f5f5f5;
  height: 100%;
}
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}
.chat-list {
  flex: 1;
  padding: 10px;
  box-sizing: border-box;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}
.chat-item {
  display: flex;
  margin-bottom: 15px;
  width: 100%;
  align-items: flex-start;
}
.my-msg {
  justify-content: flex-end;
}
.other-msg {
  justify-content: flex-start;
}
.msg-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin: 0 15rpx;
  background-color: #ddd;
}
.my-msg .msg-avatar {
  order: 2;
  margin-left: 15rpx;
  margin-right: 0;
}
.other-msg .msg-avatar {
  margin-right: 15rpx;
  margin-left: 0;
}
.msg-content {
  max-width: 65%;
  padding: 10px 15px;
  border-radius: 8px;
  font-size: 14px;
  line-height: 1.4;
  word-break: break-all;
  display: flex;
  flex-direction: column;
}
.my-msg .msg-content {
  background-color: #007aff;
  color: white;
  border-top-right-radius: 2px;
}
.other-msg .msg-content {
  background-color: white;
  color: #333;
  border-top-left-radius: 2px;
}
.msg-image {
  max-width: 100%;
  width: 200rpx;
  border-radius: 4px;
  margin-bottom: 5px;
}
.input-area {
  padding: 15rpx 20rpx;
  background: #f9f9f9;
  border-top: 1px solid #ddd;
  display: flex;
  align-items: center;
  padding-bottom: calc(15rpx + env(safe-area-inset-bottom));
  width: 100%;
  box-sizing: border-box;
  flex-shrink: 0;
}
.action-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  border-radius: 50%;
  border: 1px solid #ccc;
  background-color: white;
}
.plus-icon {
  font-size: 40rpx;
  color: #666;
  line-height: 1;
  margin-top: -4rpx;
}
.msg-input {
  flex: 1;
  background: white;
  height: 70rpx;
  border-radius: 35rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  margin-right: 20rpx;
}
.send-btn {
  width: 120rpx;
  height: 70rpx;
  line-height: 70rpx;
  background: #007aff;
  color: white;
  font-size: 28rpx;
  padding: 0;
  text-align: center;
  border-radius: 35rpx;
}
.send-btn[disabled] {
  background: #ccc;
  color: #fff;
}
