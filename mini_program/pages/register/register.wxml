<view class="container" style="padding-bottom: 300rpx;">
  <view class="header">
    <text class="title">新用户注册</text>
  </view>

  <view class="form">
    <view class="register-tabs" style="display: flex; justify-content: center; margin-bottom: 20px;">
        <view bindtap="switchRegisterType" data-type="sms" style="margin: 0 10px; padding: 5px 10px; border-bottom: {{registerType === 'sms' ? '2px solid #007aff' : 'none'}}; color: {{registerType === 'sms' ? '#007aff' : '#333'}}">手机号注册</view>
        <view bindtap="switchRegisterType" data-type="account" style="margin: 0 10px; padding: 5px 10px; border-bottom: {{registerType === 'account' ? '2px solid #007aff' : 'none'}}; color: {{registerType === 'account' ? '#007aff' : '#333'}}">账号注册</view>
        <view bindtap="switchRegisterType" data-type="email" style="margin: 0 10px; padding: 5px 10px; border-bottom: {{registerType === 'email' ? '2px solid #007aff' : 'none'}}; color: {{registerType === 'email' ? '#007aff' : '#333'}}">邮箱注册</view>
    </view>

    <!-- SMS Register Mode -->
    <block wx:if="{{registerType === 'sms'}}">
        <view class="input-group">
            <input type="number" placeholder="请输入手机号" bindinput="handleInput" data-field="phoneNumber" maxlength="11" value="{{phoneNumber}}"/>
        </view>

        <view class="input-group verify-code">
            <input type="number" placeholder="短信验证码" bindinput="handleInput" data-field="code" value="{{code}}" />
            <button class="btn-code" bindtap="sendCode" disabled="{{countdown > 0}}">
                {{countdown > 0 ? countdown + 's后重试' : '获取验证码'}}
            </button>
        </view>
        <view class="input-group">
            <input type="text" placeholder="用户名 (选填)" bindinput="handleInput" data-field="username" value="{{username}}" />
        </view>
        <view class="input-group">
            <input password type="text" placeholder="密码 (选填)" bindinput="handleInput" data-field="password" value="{{password}}" />
        </view>
        <view class="input-group">
            <input password type="text" placeholder="确认密码" bindinput="handleInput" data-field="confirmPassword" wx:if="{{password}}" value="{{confirmPassword}}" />
        </view>
    </block>

    <!-- Account Register Mode -->
    <block wx:elif="{{registerType === 'account'}}">
        <view class="input-group">
            <input type="text" placeholder="用户名 (必填)" bindinput="handleInput" data-field="username" value="{{username}}" />
        </view>
        <view class="input-group">
            <input password type="text" placeholder="密码 (必填)" bindinput="handleInput" data-field="password" value="{{password}}" />
        </view>
        <view class="input-group">
            <input password type="text" placeholder="确认密码" bindinput="handleInput" data-field="confirmPassword" value="{{confirmPassword}}" />
        </view>
        <view class="input-group">
            <input type="number" placeholder="手机号 (选填)" bindinput="handleInput" data-field="phoneNumber" maxlength="11" value="{{phoneNumber}}"/>
        </view>
    </block>

    <!-- Email Register Mode -->
    <block wx:elif="{{registerType === 'email'}}">
        <view class="input-group">
            <input type="text" placeholder="请输入邮箱" bindinput="handleInput" data-field="email" value="{{email}}" />
        </view>
        <view class="input-group verify-code">
            <input type="number" placeholder="邮箱验证码" bindinput="handleInput" data-field="emailCode" value="{{emailCode}}" />
            <button class="btn-code" bindtap="sendEmailCode" disabled="{{countdown > 0}}">
                {{countdown > 0 ? countdown + 's后重试' : '获取验证码'}}
            </button>
        </view>
    </block>

    <view class="input-group">
      <input type="text" placeholder="公司名称" bindinput="handleInput" data-field="companyName" value="{{companyName}}" />
    </view>

    <view class="input-group">
      <input type="text" placeholder="职务" bindinput="handleInput" data-field="jobTitle" />
    </view>

    <view class="input-group">
      <textarea placeholder="业务内容" bindinput="handleInput" data-field="businessContent" style="height: 100px; padding-top: 10px;" />
    </view>
    
    <view style="margin: 10px 0; font-size: 12px; color: #666; text-align: center;">
      <text>填写真实材料有助于建立可靠的合作关系</text>
    </view>

    <button class="btn-register" type="primary" bindtap="handleRegister" loading="{{loading}}">立即注册</button>
    
    <view class="footer-link">
        <text bindtap="goLogin">已有账号？去登录</text>
    </view>
  </view>
  <quick-nav />
</view>
