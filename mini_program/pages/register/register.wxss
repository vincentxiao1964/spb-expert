.container {
  padding: 40rpx;
  background-color: #fff;
  min-height: 100vh;
}

.header {
  margin-top: 50rpx;
  margin-bottom: 80rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.form {
  width: 100%;
}

.input-group {
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #eee;
  padding: 20rpx 0;
  display: flex;
  align-items: center;
}

.input-group input {
  flex: 1;
  font-size: 30rpx;
}

.verify-code {
  display: flex;
  justify-content: space-between;
}

.btn-code {
  font-size: 24rpx;
  padding: 0 20rpx;
  line-height: 60rpx;
  height: 60rpx;
  background-color: #007aff;
  color: #fff;
  border-radius: 30rpx;
  min-width: 180rpx;
}

.btn-code[disabled] {
  background-color: #ccc !important;
  color: #fff !important;
}

.btn-register {
  margin-top: 60rpx;
  width: 100%;
  border-radius: 40rpx;
}

.footer-link {
    margin-top: 30rpx;
    text-align: center;
    font-size: 28rpx;
    color: #007aff;
}
