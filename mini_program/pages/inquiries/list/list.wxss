.container { padding: 10px; background: #f5f5f5; min-height: 100vh; }
.item { background: #fff; padding: 15px; margin-bottom: 10px; border-radius: 5px; }
.title { font-size: 16px; font-weight: bold; margin-bottom: 5px; }
.status { color: #ff6600; font-size: 14px; margin-bottom: 5px; }
.time { color: #999; font-size: 12px; }
.empty { text-align: center; margin-top: 50px; color: #999; }
