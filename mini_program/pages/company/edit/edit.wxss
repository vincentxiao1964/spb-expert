.container {
  padding: 30rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.section-title {
    font-size: 32rpx;
    font-weight: bold;
    margin: 30rpx 0 20rpx;
    color: #333;
}

.form-group {
  background: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 8rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  font-size: 30rpx;
  color: #333;
  height: 60rpx;
}

.textarea {
    width: 100%;
    font-size: 30rpx;
    color: #333;
    min-height: 150rpx;
}

.btn-submit {
  margin-top: 50rpx;
  background-color: #007aff;
  color: #fff;
  border-radius: 8rpx;
}

.image-uploader {
  width: 200rpx;
  height: 200rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
  border: 1rpx dashed #ccc;
}

.uploaded-img {
  width: 100%;
  height: 100%;
}

.placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
}

.plus {
  font-size: 60rpx;
  line-height: 60rpx;
  margin-bottom: 10rpx;
}
