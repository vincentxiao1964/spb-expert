.container {
  padding: 20rpx;
  padding-bottom: 300rpx;
}

.header {
  margin-bottom: 20rpx;
  display: flex;
  justify-content: flex-end;
}

.list {
  background: #fff;
}

.item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1px solid #eee;
}

.item-content {
  flex: 1;
}

.item-title {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.tag-type {
  font-size: 24rpx;
  background: #e6f7ff;
  color: #1890ff;
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  margin-right: 10rpx;
}

.tag-category {
  font-size: 24rpx;
  background: #f9f0ff;
  color: #722ed1;
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  margin-right: 10rpx;
}

.text-dwt {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.item-info {
  display: flex;
  align-items: center;
}

.item-status {
  font-size: 24rpx;
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  margin-right: 10rpx;
}

.status-approved {
  background: #f6ffed;
  color: #52c41a;
}

.status-pending {
  background: #fffbe6;
  color: #faad14;
}

.item-date {
  font-size: 24rpx;
  color: #999;
}

.item-actions {
  display: flex;
  margin-left: 20rpx;
}

.btn-action {
  font-size: 26rpx;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  margin-left: 10rpx;
}

.btn-edit {
  background: #f0f0f0;
  color: #333;
}

.btn-approve {
  background: #f6ffed;
  color: #52c41a;
  border: 1px solid #b7eb8f;
}

.btn-reject {
  background: #fff1f0;
  color: #f5222d;
  border: 1px solid #ffa39e;
}

.btn-delete {
  background: #fff1f0;
  color: #f5222d;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 40rpx;
}