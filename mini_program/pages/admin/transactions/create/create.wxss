.container {
    padding: 20rpx;
    background-color: #f5f5f5;
    min-height: 100vh;
}

.steps {
    display: flex;
    justify-content: space-between;
    margin-bottom: 30rpx;
    background: #fff;
    padding: 20rpx;
    border-radius: 10rpx;
}

.step {
    color: #999;
    font-size: 28rpx;
}

.step.active {
    color: #007aff;
    font-weight: bold;
}

.search-box {
    background: #fff;
    padding: 20rpx;
    border-radius: 10rpx;
    margin-bottom: 20rpx;
}

.search-box input {
    height: 60rpx;
    font-size: 28rpx;
}

.result-item {
    background: #fff;
    padding: 20rpx;
    border-bottom: 1rpx solid #eee;
}

.title {
    font-size: 30rpx;
    font-weight: bold;
    margin-bottom: 10rpx;
}

.sub {
    font-size: 24rpx;
    color: #666;
}

.selected-info {
    background: #e6f3ff;
    padding: 20rpx;
    margin-bottom: 20rpx;
    border-radius: 10rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 28rpx;
    color: #007aff;
}

.reselect {
    text-decoration: underline;
}

.confirm-card {
    background: #fff;
    padding: 40rpx;
    border-radius: 20rpx;
}

.section-title {
    font-size: 36rpx;
    font-weight: bold;
    margin-bottom: 40rpx;
    text-align: center;
}

.info-row {
    margin-bottom: 30rpx;
    display: flex;
    justify-content: space-between;
}

.label {
    color: #666;
    width: 150rpx;
}

.value {
    font-weight: bold;
    flex: 1;
    text-align: right;
}

/* New Styles */
.form-group {
    background: #fff;
    padding: 30rpx;
    border-radius: 10rpx;
    margin-bottom: 40rpx;
}

.form-group .label {
    font-size: 30rpx;
    color: #333;
    font-weight: bold;
    margin-bottom: 20rpx;
    display: block;
    width: 100%;
}

.input-field {
    border: 1rpx solid #eee;
    padding: 20rpx;
    border-radius: 8rpx;
    font-size: 28rpx;
    margin-bottom: 15rpx;
    background: #f9f9f9;
}

.hint {
    font-size: 24rpx;
    color: #999;
}

.btn-next {
    margin-top: 40rpx;
}

.btn-submit {
    margin-bottom: 20rpx;
}

.btn-back {
    margin-top: 20rpx;
    background: #f5f5f5;
    color: #666;
}

.current-selection {
    margin-bottom: 20rpx;
}

.result-item.selected {
    border: 2rpx solid #007aff;
    background: #f0f7ff;
}
