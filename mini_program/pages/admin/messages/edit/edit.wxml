<view class="container">
  <form bindsubmit="submitForm">
    <view class="form-group">
      <view class="label">留言内容</view>
      <textarea class="textarea" name="content" value="{{content}}" placeholder="请输入留言内容" maxlength="500"></textarea>
    </view>

    <view class="btn-area">
      <button formType="submit" class="btn-submit" loading="{{isSubmitting}}">保存修改</button>
      <button type="warn" class="btn-delete-topic" bindtap="deleteTopic">删除帖子</button>
    </view>
  </form>

  <view class="reply-section">
    <view class="reply-title">回复列表 ({{replies.length}})</view>
    <block wx:for="{{replies}}" wx:key="id">
      <view class="reply-item">
        <view class="reply-header">
          <text class="reply-user">{{item.user_name}}</text>
          <text class="reply-date">{{item.created_at}}</text>
        </view>
        <view class="reply-content">{{item.content}}</view>
        <view class="reply-actions">
          <button type="warn" size="mini" class="btn-delete-reply" data-id="{{item.id}}" bindtap="deleteReply">删除</button>
        </view>
      </view>
    </block>
    <view wx:if="{{replies.length === 0}}" class="empty-tip">
      <text>暂无回复</text>
    </view>
  </view>
</view>
