.container {
  padding: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: bold;
}

.textarea {
  width: 100%;
  height: 300rpx;
  background: #f8f8f8;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  border-radius: 8rpx;
}

.btn-area {
  margin-top: 50rpx;
}

.btn-submit {
  background: #007aff;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
}

.btn-delete-topic {
  margin-top: 20rpx;
  border-radius: 44rpx;
}

.reply-section {
  margin-top: 40rpx;
}

.reply-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.reply-item {
  padding: 20rpx;
  border-radius: 12rpx;
  background: #fff;
  border: 1rpx solid #eee;
  margin-bottom: 16rpx;
}

.reply-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.reply-user {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
}

.reply-date {
  font-size: 22rpx;
  color: #999;
}

.reply-content {
  font-size: 26rpx;
  color: #444;
  white-space: pre-wrap;
}

.reply-actions {
  margin-top: 14rpx;
  display: flex;
  justify-content: flex-end;
}

.empty-tip {
  text-align: center;
  color: #999;
  margin-top: 20rpx;
}
