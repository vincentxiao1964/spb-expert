.container {
  padding: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: bold;
}

.textarea {
  width: 100%;
  height: 300rpx;
  background: #f8f8f8;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  border-radius: 8rpx;
}

.btn-area {
  margin-top: 50rpx;
}

.btn-submit {
  background: #007aff;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
}