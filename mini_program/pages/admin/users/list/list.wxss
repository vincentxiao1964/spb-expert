.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.search-bar {
  display: flex;
  padding: 20rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-input {
  flex: 1;
  background: #f0f0f0;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
}

.search-btn {
  margin-left: 20rpx;
  color: #007aff;
  font-size: 28rpx;
  line-height: 60rpx;
}

.user-list {
  padding: 20rpx;
  height: calc(100vh - 100rpx);
}

.user-item {
  background: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.user-company {
  font-size: 24rpx;
  color: #666;
  font-weight: normal;
  margin-left: 10rpx;
}

.user-meta {
  margin-top: 10rpx;
}

.user-phone {
  color: #007aff;
  font-size: 28rpx;
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
}