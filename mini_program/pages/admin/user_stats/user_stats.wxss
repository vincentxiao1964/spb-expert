.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.stat-card {
  background: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  width: 45%;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.value {
  font-size: 40rpx;
  font-weight: bold;
}

.text-green { color: #07c160; }
.text-blue { color: #1890ff; }

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin: 30rpx 0 20rpx;
  padding-left: 20rpx;
  border-left: 8rpx solid #1890ff;
}

.chart-container {
  background: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.list-container {
  background: #fff;
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.list-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.list-item:last-child {
  border-bottom: none;
}

.row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.user { font-weight: bold; font-size: 28rpx; }
.ip { font-size: 24rpx; color: #999; }
.path { font-size: 24rpx; color: #666; flex: 1; margin-right: 20rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.time { font-size: 24rpx; color: #ccc; }
.empty-text { text-align: center; color: #999; padding: 30rpx; }