.container { background: #f5f5f5; min-height: 100vh; }
.tabs { display: flex; background: #fff; padding: 10px; border-bottom: 1px solid #eee; position: sticky; top: 0; z-index: 10; }
.tab-item { flex: 1; text-align: center; font-size: 14px; color: #666; padding-bottom: 5px; }
.tab-item.active { color: #007aff; border-bottom: 2px solid #007aff; font-weight: bold; }
.order-list { padding: 10px; }
.order-item { background: #fff; margin-bottom: 10px; padding: 15px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
.header { display: flex; justify-content: space-between; border-bottom: 1px solid #f9f9f9; padding-bottom: 10px; margin-bottom: 10px; font-size: 12px; color: #999; }
.status { color: #ff6600; font-weight: bold; }
.item-info { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 14px; color: #333; }
.title { flex: 1; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; padding-right: 10px; }
.qty { color: #999; width: 40px; text-align: right; }
.price { width: 80px; text-align: right; font-weight: 500; }
.footer { text-align: right; font-weight: bold; font-size: 16px; border-top: 1px solid #f9f9f9; padding-top: 10px; margin-top: 5px; color: #e64340; }
.empty { text-align: center; color: #999; margin-top: 100px; font-size: 14px; }
