.container { padding-bottom: 80px; background: #f5f5f5; min-height: 100vh; }
.status-header { background: #ff6600; color: #fff; padding: 20px; }
.status-text { font-size: 18px; font-weight: bold; display: block; margin-bottom: 5px; }
.order-number { font-size: 12px; opacity: 0.8; }
.address-section { background: #fff; padding: 15px; margin-bottom: 10px; }
.contact-row { font-weight: bold; margin-bottom: 5px; }
.name { margin-right: 10px; }
.item-list { background: #fff; margin-bottom: 10px; padding: 0 15px; }
.item { padding: 15px 0; border-bottom: 1px solid #f5f5f5; }
.item:last-child { border-bottom: none; }
.item-main { display: flex; justify-content: space-between; }
.item-title { flex: 1; margin-right: 10px; font-size: 14px; }
.item-price-qty { text-align: right; }
.price { display: block; color: #333; font-weight: 500; }
.qty { display: block; color: #999; font-size: 12px; }
.order-info { background: #fff; padding: 15px; margin-bottom: 10px; }
.info-row { display: flex; justify-content: space-between; margin-bottom: 10px; font-size: 14px; color: #666; }
.total-row { border-top: 1px solid #f5f5f5; padding-top: 10px; margin-top: 10px; color: #333; font-weight: bold; font-size: 16px; }
.total-row .price { color: #e64340; }
.footer-actions { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 10px; display: flex; justify-content: flex-end; border-top: 1px solid #eee; }
.btn { margin-left: 10px; font-size: 14px; padding: 5px 15px; border-radius: 20px; }
.btn-primary { background: #ff6600; color: #fff; border: 1px solid #ff6600; }
.btn-outline { background: #fff; color: #666; border: 1px solid #ccc; }
