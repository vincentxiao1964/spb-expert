.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.txn-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.txn-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.txn-id {
    color: #999;
    font-size: 24rpx;
}

.txn-status {
    font-size: 26rpx;
    padding: 4rpx 12rpx;
    border-radius: 8rpx;
    background: #eee;
}
.txn-status.INITIATED { background: #e3f2fd; color: #1976d2; }

.txn-title {
    font-size: 32rpx;
    font-weight: bold;
    margin-bottom: 10rpx;
}

.txn-date {
    font-size: 24rpx;
    color: #999;
}

.empty-state {
    text-align: center;
    margin-top: 100rpx;
    color: #999;
}