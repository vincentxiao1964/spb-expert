.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.header {
  margin-bottom: 30rpx;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
  color: #333;
}

.subtitle {
  font-size: 24rpx;
  color: #888;
}

.form-group {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 0 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #eee;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 200rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

input, .picker {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.submit-btn {
  margin-top: 50rpx;
  background-color: #007aff !important;
  font-weight: bold;
  box-shadow: 0 4rpx 10rpx rgba(0,122,255,0.3);
}

.results-section {
  margin-top: 50rpx;
  padding-bottom: 50rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 8rpx solid #007aff;
  color: #333;
}

.match-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 1px solid #f0f0f0;
}

.match-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f9f9f9;
}

.ship-title {
  display: flex;
  align-items: center;
}

.view-status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #ff4d4f;
  margin-right: 10rpx;
}

.ship-name {
  font-weight: bold;
  font-size: 32rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 70%;
}

.score-badge {
    background-color: #e6f7ff;
    padding: 4rpx 16rpx;
    border-radius: 20rpx;
    border: 1px solid #bae7ff;
}

.score-val {
    color: #007aff;
    font-weight: bold;
    font-size: 30rpx;
}

.score-unit {
    color: #007aff;
    font-size: 20rpx;
    margin-left: 2rpx;
}

.match-info {
    margin-bottom: 20rpx;
}

.info-row {
    display: flex;
    margin-bottom: 10rpx;
    align-items: center;
}

.info-row .label {
    color: #888;
    width: 140rpx;
    font-size: 26rpx;
    text-align: left;
    font-weight: normal;
}

.info-row .val {
    color: #333;
    font-size: 26rpx;
    font-weight: 500;
}

.card-footer {
    display: flex;
    justify-content: flex-end;
    padding-top: 10rpx;
    border-top: 1px dashed #f5f5f5;
}

.view-detail {
    font-size: 24rpx;
    color: #007aff;
    padding: 10rpx 0;
}

.no-results {
    text-align: center;
    color: #999;
    margin-top: 50rpx;
    font-size: 28rpx;
}
