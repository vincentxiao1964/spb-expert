.container {
  padding: 20rpx;
  padding-bottom: 120rpx; /* Space for footer-tabbar */
}
.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.date {
  color: #999;
  font-size: 24rpx;
  margin-bottom: 0;
}
.favorite-btn {
  display: flex;
  align-items: center;
  color: #666;
  font-size: 28rpx;
}
.favorite-btn .iconfont {
  margin-right: 6rpx;
  font-size: 32rpx;
}
.icon-star-filled {
  color: #ffc107;
}

.author-section {
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 30rpx;
}
.author-info {
  margin-bottom: 16rpx;
}
.author-name {
  font-weight: bold;
  font-size: 30rpx;
}
.action-buttons {
  display: flex;
  gap: 20rpx;
}
.btn-action {
  margin: 0;
  font-size: 24rpx;
  padding: 0 30rpx;
  line-height: 2.4;
}
.btn-follow {
  background-color: #fff;
  color: #007aff;
  border: 1px solid #007aff;
}
.btn-follow.active {
  background-color: #007aff;
  color: #fff;
}
.btn-contact {
  background-color: #fff;
  color: #17a2b8;
  border: 1px solid #17a2b8;
}

.cover {
  width: 100%;
  margin-bottom: 20rpx;
}
.content {
  font-size: 30rpx;
  line-height: 1.6;
}
.loading, .error {
  text-align: center;
  margin-top: 100rpx;
  color: #999;
  font-size: 30rpx;
}
