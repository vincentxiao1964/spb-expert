.container { padding: 20px; }
.rating-section { display: flex; align-items: center; margin-bottom: 20px; }
.label { font-size: 16px; margin-right: 15px; }
.stars { display: flex; }
.star { font-size: 30px; color: #ccc; margin-right: 5px; }
.star.active { color: #ffcc00; }
.comment-section textarea { width: 100%; height: 150px; background: #f9f9f9; padding: 10px; border-radius: 5px; font-size: 14px; box-sizing: border-box; }
.btn-area { margin-top: 30px; }
